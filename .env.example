# ─── AIS VESSEL TRACKING (pick ONE — priority: AISStream > AISHub > MarineTraffic) ──
#
# OPTION 1 — AISStream (recommended, free, real-time WebSocket)
#   Sign up: https://aisstream.io → Dashboard → API Keys
AISSTREAM_API_KEY=your_aisstream_api_key_here
#
# OPTION 2 — AISHub (free, REST polling every 60s)
#   Sign up: https://www.aishub.net/register
AISHUB_USERNAME=your_aishub_username_here
#
# OPTION 3 — MarineTraffic (paid, premium REST data)
#   Sign up: https://www.marinetraffic.com/en/online-services/plans
MARINETRAFFIC_API_KEY=your_marinetraffic_api_key_here

